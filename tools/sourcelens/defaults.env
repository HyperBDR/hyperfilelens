# SourceLens bundle settings for release/build.sh
# Override via environment variables or CLI (--no-sourcelens, --sourcelens-ref).

# Bundle SourceLens into the HyperFileLens release package (1=yes, 0=no).
BUILD_SOURCELENS="${BUILD_SOURCELENS:-1}"

# Git source (HTTPS or SSH).
SOURCELENS_GIT_URL="${SOURCELENS_GIT_URL:-https://github.com/HyperBDR/sourcelens.git}"
# SOURCELENS_GIT_URL=git@github.com:HyperBDR/sourcelens.git
# Private HTTPS clone: set GITHUB_TOKEN in the environment (or pass --github-token to dev/stack.sh or release/build.sh).

# Tested SourceLens release tag. This is the only SourceLens version input.
# Docker image and runtime versions are derived by removing the leading "v".
SOURCELENS_GIT_REF="${SOURCELENS_GIT_REF:-v0.4.0}"

# SourceLens upstream Compose builds into oneprocloud/* first. HFL then tags
# normalized hyperfilelens-sourcelens-* images without modifying upstream code.
SOURCELENS_UPSTREAM_IMAGE_PREFIX="${SOURCELENS_UPSTREAM_IMAGE_PREFIX:-oneprocloud}"

# Optional registry/namespace for normalized distribution images, for example
# ghcr.io/example or registry.example.com/group/project. Empty means local names.
SOURCELENS_IMAGE_REGISTRY="${SOURCELENS_IMAGE_REGISTRY:-}"

# Standalone SourceLens HTTPS console port. HFL API/WSS traffic still uses 11443/sourcelens.
SOURCELENS_NGINX_HTTPS_PORT="${SOURCELENS_NGINX_HTTPS_PORT:-11445}"

# Runtime install directory on the control-plane host.
SOURCELENS_INSTALL_DIR="${SOURCELENS_INSTALL_DIR:-/opt/hyperfilelens/sourcelens}"

# Embed local sourcelens-lensnode in SL compose (0=DG-only; lensnode image still built for gateway-bootstrap).
SOURCELENS_EMBED_LENSNODE="${SOURCELENS_EMBED_LENSNODE:-0}"

# Bundled .env.example is patched to DJANGO_DEBUG=true (see deploy/installer/sourcelens/patch-env-runtime.py).

# Build mirrors (fallback to release/build.sh mirror environment when unset).
# Base images (ubuntu/python/node/nginx) use docker.io in Dockerfile FROM lines, same as HFL compose build.
# Docker Hub acceleration relies on the host daemon registry-mirrors when configured.
# SourceLens defaults to linux/amd64 so release/dev image exports match the
# linux-amd64 LensNode bundle name. Override only when intentionally building
# native images, for example SOURCELENS_DOCKER_PLATFORM=linux/arm64.
# SOURCELENS_DOCKER_PLATFORM=linux/amd64
# SOURCELENS_APT_MIRROR may be either a mirror root (for example
# https://mirrors.tuna.tsinghua.edu.cn) or a full Ubuntu apt path ending in
# /ubuntu or /ubuntu-ports.
# SOURCELENS_APT_MIRROR=
# SOURCELENS_PIP_INDEX_URL=
# SOURCELENS_PIP_TRUSTED_HOST=
# SOURCELENS_UV_HTTP_TIMEOUT=120
# SOURCELENS_UV_CONCURRENT_DOWNLOADS=2
# SOURCELENS_PIP_RETRY_MAX=5
# SOURCELENS_PIP_RETRY_DELAY=5
# SOURCELENS_NPM_REGISTRY=
