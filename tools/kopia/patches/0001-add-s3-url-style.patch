+func bucketLookupForURLStyle(urlStyle string) (minio.BucketLookupType, error) {
+	switch urlStyle {
+	case "", URLStyleAuto:
+		return minio.BucketLookupAuto, nil
+	case URLStyleVirtualHosted:
+		return minio.BucketLookupDNS, nil
+	case URLStylePath:
+		return minio.BucketLookupPath, nil
+	default:
+		return minio.BucketLookupAuto, errors.Errorf("invalid S3 URL style: %q", urlStyle)
+	}
+}
