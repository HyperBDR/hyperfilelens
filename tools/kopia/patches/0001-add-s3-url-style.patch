+func TestBucketLookupForURLStyle(t *testing.T) {
+	t.Parallel()
+
+	tests := []struct {
+		name      string
+		urlStyle  string
+		expected  minio.BucketLookupType
+		wantError bool
+	}{
+		{"empty defaults to auto", "", minio.BucketLookupAuto, false},
+		{"auto", URLStyleAuto, minio.BucketLookupAuto, false},
+		{"virtual hosted", URLStyleVirtualHosted, minio.BucketLookupDNS, false},
+		{"path", URLStylePath, minio.BucketLookupPath, false},
+		{"invalid", "invalid", minio.BucketLookupAuto, true},
+	}
+
+	for _, tc := range tests {
+		t.Run(tc.name, func(t *testing.T) {
+			actual, err := bucketLookupForURLStyle(tc.urlStyle)
+			if tc.wantError {
+				require.Error(t, err)
+				return
+			}
+			require.NoError(t, err)
+			require.Equal(t, tc.expected, actual)
+		})
+	}
+}
+
+func TestOptionsURLStyleJSONRoundTrip(t *testing.T) {
+	t.Parallel()
+
+	original := Options{URLStyle: URLStyleVirtualHosted}
+	encoded, err := json.Marshal(original)
+	require.NoError(t, err)
+
+	var decoded Options
+	require.NoError(t, json.Unmarshal(encoded, &decoded))
+	require.Equal(t, original.URLStyle, decoded.URLStyle)
+}
+
+func TestURLStyleRequestAddressing(t *testing.T) {
+	t.Parallel()
+
+	tests := []struct {
+		name         string
+		urlStyle     string
+		expectedHost string
+		expectedPath string
+	}{
+		{"virtual hosted", URLStyleVirtualHosted, "backup-bucket.s3.example.test", "/object"},
+		{"path", URLStylePath, "s3.example.test", "/backup-bucket/object"},
+	}
+
+	for _, tc := range tests {
+		t.Run(tc.name, func(t *testing.T) {
+			lookup, err := bucketLookupForURLStyle(tc.urlStyle)
+			require.NoError(t, err)
+			client, err := minio.New("s3.example.test", &minio.Options{
+				Creds:        credentials.NewStaticV4("access-key", "secret-key", ""),
+				Secure:       false,
+				Region:       "us-east-1",
+				BucketLookup: lookup,
+			})
+			require.NoError(t, err)
+			requestURL, err := client.PresignedGetObject(
+				context.Background(), "backup-bucket", "object", time.Hour, nil,
+			)
+			require.NoError(t, err)
+			require.Equal(t, tc.expectedHost, requestURL.Host)
+			require.Equal(t, tc.expectedPath, requestURL.Path)
+		})
+	}
+}
