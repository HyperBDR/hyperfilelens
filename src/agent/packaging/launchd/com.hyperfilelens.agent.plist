<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Template reference for macOS LaunchDaemon integration.
  install.sh writes the live plist to /Library/LaunchDaemons/ with resolved paths.
-->
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.hyperfilelens.agent</string>
	<key>ProgramArguments</key>
	<array>
		<string>/opt/hyperfilelens-agent/run-agent.sh</string>
	</array>
	<key>RunAtLoad</key>
	<true/>
	<key>KeepAlive</key>
	<true/>
	<key>WorkingDirectory</key>
	<string>/opt/hyperfilelens-agent</string>
	<key>StandardOutPath</key>
	<string>/var/lib/hyperfilelens-agent/logs/launchd.stdout.log</string>
	<key>StandardErrorPath</key>
	<string>/var/lib/hyperfilelens-agent/logs/launchd.stderr.log</string>
</dict>
</plist>
