# HyperFileLens environment configuration
#
# Local development:
#   ./dev/stack.sh up
#
# The development command copies this file to .env when .env does not exist.
# Release packages include the same template; install.sh generates production
# secrets, version values, and host-specific URLs before starting services.
#
# Never commit .env or real credentials. Values in this file are safe local
# development defaults unless a comment explicitly marks a value as optional.
# Build option precedence is: CLI flag, process environment, .env, then this file.

# ==============================================================================
# Application version and mode
# ==============================================================================

# HyperFileLens image and API version. The release installer replaces this value.
APP_VERSION=0.1.0

# Agent release selected by the control plane. The release installer replaces it.
AGENT_VERSION=0.1.0

# Enable HFL Django diagnostics and development error pages. Release installs set false.
DJANGO_DEBUG=true

# Django cryptographic signing key. Release installs generate a random value.
SECRET_KEY=dev-only-change-me

# ==============================================================================
# PostgreSQL
# ==============================================================================

# PostgreSQL database name.
POSTGRES_DB=hyperfilelens

# PostgreSQL application user.
POSTGRES_USER=postgres

# PostgreSQL password. Release installs generate a random value.
POSTGRES_PASSWORD=postgres

# PostgreSQL Compose service hostname.
POSTGRES_HOST=postgres

# PostgreSQL container port.
POSTGRES_PORT=5432

# Optional PostgreSQL URL; when empty, the POSTGRES_* values above are used.
# Other database engines are not supported.
DATABASE_URL=

# ==============================================================================
# Redis, cache, and task queue
# ==============================================================================

# Redis connection used by Django Channels.
REDIS_URL=redis://redis:6379/0

# Redis connection used by Celery as its message broker.
CELERY_BROKER_URL=redis://redis:6379/0

# Django cache backend: redis, memcached, database, or locmem.
CACHE_BACKEND=redis

# Redis connection used by the Django cache.
CACHE_REDIS_URL=redis://redis:6379/1

# Time zone used by Celery schedules.
CELERY_TIMEZONE=UTC

# Default Celery queue name.
CELERY_TASK_DEFAULT_QUEUE=backend

# Celery logging threshold.
CELERY_LOG_LEVEL=INFO

# ==============================================================================
# Public listeners and canonical URLs
# ==============================================================================

# Host interface for the tenant HTTPS console.
HFL_TENANT_BIND_ADDRESS=0.0.0.0

# Host port for the tenant HTTPS console.
HFL_TENANT_PORT=11443

# Host interface for Platform Operations and Django Admin.
HFL_ADMIN_BIND_ADDRESS=0.0.0.0

# Host port for Platform Operations and Django Admin.
HFL_ADMIN_PORT=11444

# Canonical browser URL used in redirects, email links, and gateway enrollment.
FRONTEND_URL=https://127.0.0.1:11443

# Optional canonical Platform Operations URL. Empty derives the direct listener URL.
HFL_ADMIN_PUBLIC_URL=

# Comma-separated hostnames accepted by Django.
DJANGO_ALLOWED_HOSTS=*

# ==============================================================================
# Reverse proxy and browser security
# ==============================================================================

# Trust the bundled Nginx X-Forwarded-Proto header for HTTPS detection.
TRUSTED_PROXY=true

# Treat authentication cookies as HTTPS-only.
COOKIE_SECURE=true

# Optional comma-separated trusted CSRF origins, including scheme and port.
CSRF_TRUSTED_ORIGINS=

# Optional comma-separated CORS origins; same-origin deployments may leave empty.
CORS_ALLOWED_ORIGINS=

# Keep cross-origin access disabled unless explicitly required.
CORS_ALLOW_ALL_ORIGINS=false

# Redirect direct HTTP requests to HTTPS inside Django.
SECURE_SSL_REDIRECT=false

# Optional HSTS duration in seconds; enable only after validating HTTPS deployment.
SECURE_HSTS_SECONDS=0

# Apply HSTS to subdomains when HSTS is enabled.
SECURE_HSTS_INCLUDE_SUBDOMAINS=false

# Allow browser preload submission when HSTS is enabled and fully validated.
SECURE_HSTS_PRELOAD=false

# ==============================================================================
# Initial organization and administrator
# ==============================================================================

# Seed the initial organization and administrator on the first worker start.
SEED_INITIAL_DATA=1

# Name of the initial organization.
SEED_ORG_NAME=HyperFileLens

# Email address of the initial administrator.
SEED_ADMIN_EMAIL=admin@hyperfilelens.com

# Fixed default administrator password used only when the account is first created.
SEED_ADMIN_PASSWORD=Admin@123

# ==============================================================================
# Product features
# ==============================================================================

# Allow users to create accounts with email and password.
HFL_EMAIL_SIGNUP_ENABLED=false

# Allow users to sign in with Google. Google OAuth credentials are also required.
HFL_GOOGLE_OAUTH_ENABLED=false

# Enable the Platform Operations console.
HFL_PLATFORM_OPS_ENABLED=true

# Automatically deploy an HFL-managed local platform Data Gateway during installation.
# Setting this to false does not remove an existing platform Gateway.
HFL_PLATFORM_GATEWAY_AUTO_DEPLOY=false

# Allow users to initiate password resets.
HFL_SELF_SERVICE_PASSWORD_RESET=true

# Optional comma-separated CIDRs allowed to access Platform Operations.
HFL_PLATFORM_OPS_ALLOWED_CIDRS=

# Hide the commercial EULA notice in open-source frontend builds.
VITE_SHOW_EULA=false

# Disable development-only in-memory demo records.
VITE_ENABLE_DEMO_DATA=false

# ==============================================================================
# Runtime files and Agent publishing
# ==============================================================================

# Kopia package copied into the development backend image.
KOPIA_DEB=build/dependencies/kopia/kopia_linux_amd64.deb

# Optional backend media root override; containers default to /opt/backend/media.
# HFL_MEDIA_ROOT=/opt/backend/media

# Optional Agent release directory; defaults to <HFL_MEDIA_ROOT>/agent-releases.
# AGENT_RELEASES_DIR=/opt/backend/media/agent-releases

# Optional enrollment bootstrap directory; containers default to /opt/bootstrap.
# HFL_BOOTSTRAP_DIR=/opt/bootstrap

# Optional installed language-pack root; English is built in.
# HFL_LANG_PACKS_DIR=/opt/backend/lang-packs

# ==============================================================================
# SourceLens integration
# ==============================================================================

# Integration mode: bundled manages packaged images; external uses an existing service.
SOURCELENS_MODE=bundled

# Bundled SourceLens currently keeps its own DJANGO_DEBUG=true compatibility patch.
# The HFL DJANGO_DEBUG value above does not change the SourceLens runtime setting.

# Host interface for the standalone SourceLens HTTPS console.
SOURCELENS_CONSOLE_BIND_ADDRESS=0.0.0.0

# Host port for the standalone SourceLens HTTPS console.
SOURCELENS_CONSOLE_PORT=11445

# SourceLens URL reachable from HyperFileLens containers.
LENS_BASE_URL=http://sourcelens-nginx

# Optional SourceLens URL reachable from enrolled Data Gateway hosts.
LENS_GATEWAY_BASE_URL=

# SourceLens service account username used by the HFL bridge.
LENS_BRIDGE_USERNAME=admin

# SourceLens service account password; keep synchronized with bundled SourceLens.
LENS_BRIDGE_PASSWORD=adminpassword

# Allow self-signed SourceLens and HFL certificates for gateway enrollment.
HFL_INSECURE_TLS=1

# SourceLens release tag used by local development and release builds.
SOURCELENS_GIT_REF=v0.4.0

# SourceLens Git repository used only as an image build input.
SOURCELENS_GIT_URL=https://github.com/HyperBDR/sourcelens.git

# Build and bundle SourceLens images in local release workflows.
BUILD_SOURCELENS=1

# ==============================================================================
# Human verification and OAuth
# ==============================================================================

# Require Cloudflare Turnstile on protected anonymous authentication endpoints.
# Keep disabled for local development and private deployments.
TURNSTILE_ENABLED=false

# Cloudflare Turnstile site key; required when TURNSTILE_ENABLED=true.
TURNSTILE_SITE_KEY=

# Cloudflare Turnstile secret key; required when TURNSTILE_ENABLED=true.
TURNSTILE_SECRET_KEY=

# Google OAuth client ID; leave empty to hide Google sign-in.
GOOGLE_CLIENT_ID=

# Google OAuth client secret; required when GOOGLE_CLIENT_ID is configured.
GOOGLE_CLIENT_SECRET=

# OAuth provider request timeout in seconds; empty selects an automatic default.
SOCIALACCOUNT_REQUESTS_TIMEOUT=

# ==============================================================================
# Email
# ==============================================================================

# Email backend. The console backend keeps a zero-configuration install usable.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# SMTP server hostname; used when EMAIL_BACKEND selects the SMTP backend.
EMAIL_HOST=

# SMTP server port.
EMAIL_PORT=587

# Enable STARTTLS for SMTP connections.
EMAIL_USE_TLS=true

# Enable implicit TLS for SMTP connections; do not combine with EMAIL_USE_TLS.
EMAIL_USE_SSL=false

# SMTP account username.
EMAIL_HOST_USER=

# SMTP account password or application password.
EMAIL_HOST_PASSWORD=

# Sender shown in outbound messages.
DEFAULT_FROM_EMAIL=HyperFileLens <noreply@hyperfilelens.local>

# ==============================================================================
# Observability and logging
# ==============================================================================

# Enable Sentry for backend services and frontend release builds.
SENTRY_ENABLED=false

# Sentry data source name; required when SENTRY_ENABLED=true.
SENTRY_DSN=

# Optional deployment label reported to Sentry; release builds default to production.
SENTRY_ENVIRONMENT=

# Release identifier; empty falls back to APP_VERSION.
SENTRY_RELEASE=

# Fraction of transactions traced by Sentry, from 0.0 to 1.0.
SENTRY_TRACES_SAMPLE_RATE=0

# Fraction of traced transactions profiled by the backend, from 0.0 to 1.0.
SENTRY_PROFILES_SAMPLE_RATE=0

# Include personally identifiable information in Sentry events.
SENTRY_SEND_DEFAULT_PII=false

# Backend logging threshold.
LOG_LEVEL=INFO

# Enable the Prometheus-style metrics endpoint.
ENABLE_METRICS=false

# ==============================================================================
# Optional AI providers
# ==============================================================================

# OpenAI-compatible API key; it can also be configured in Platform Operations.
OPENAI_API_KEY=

# OpenAI-compatible API base URL.
OPENAI_API_BASE=https://api.openai.com/v1

# Azure OpenAI API key.
AZURE_OPENAI_API_KEY=

# Azure OpenAI endpoint URL.
AZURE_OPENAI_API_BASE=

# Google Gemini API key; GOOGLE_API_KEY is also accepted for compatibility.
GEMINI_API_KEY=

# Enable Langfuse tracing after configuring its public and secret keys.
LANGFUSE_ENABLED=false

# Langfuse public key.
LANGFUSE_PUBLIC_KEY=

# Langfuse secret key.
LANGFUSE_SECRET_KEY=

# Langfuse service URL.
LANGFUSE_BASE_URL=

# ==============================================================================
# Optional outbound proxy
# ==============================================================================

# HTTP proxy used by backend outbound requests.
HTTP_PROXY=

# HTTPS proxy used by backend outbound requests.
HTTPS_PROXY=

# Hosts and service names that bypass HTTP(S)_PROXY.
NO_PROXY=localhost,127.0.0.1,host.docker.internal,postgres,postgresql,redis,api,worker,scheduler,ui,nginx,sourcelens-nginx

# ==============================================================================
# Build and download sources
# ==============================================================================

# Optional GitHub release download prefix, for example https://ghfast.top.
GITHUB_DOWNLOAD_MIRROR=

# Optional GitHub token for private clones and API rate limits; never commit a value.
GITHUB_TOKEN=

# Optional Docker Hub image prefix, for example docker.m.daocloud.io.
DOCKER_DOWNLOAD_MIRROR=

# Maximum time in seconds for each Docker image pull attempt.
DOCKER_PULL_TIMEOUT_SECONDS=180
DOCKER_PULL_RETRIES=2

# Development stack network policy. Set to 1 to require all Git sources,
# dependencies, and Docker images to be available from local caches.
DEV_OFFLINE=0

# SourceLens Git network operations use the same finite-wait policy.
SOURCELENS_GIT_TIMEOUT_SECONDS=120
SOURCELENS_GIT_RETRIES=2

# Browser image/package version used by ./dev/stack.sh smoke.
DEV_SMOKE_PLAYWRIGHT_VERSION=1.55.0

# Browser images are much larger than normal runtime images and need a separate bound.
DEV_SMOKE_PULL_TIMEOUT_SECONDS=900

# Docker CE apt repository used for offline host packages.
DOCKER_APT_MIRROR=https://download.docker.com/linux/ubuntu

# Optional Ubuntu mirror root, for example https://mirrors.tuna.tsinghua.edu.cn.
APT_MIRROR=

# Optional Python package index, for example https://pypi.org/simple.
PIP_INDEX_URL=

# Optional trusted pip hostname for indexes without valid public TLS.
PIP_TRUSTED_HOST=

# Python package download timeout in seconds.
PIP_TIMEOUT=600

# Optional npm registry, for example https://registry.npmjs.org.
NPM_REGISTRY=

# Go module proxy used by Agent builds.
GOPROXY=https://proxy.golang.org,direct

# Go checksum database used by Agent builds.
GOSUMDB=sum.golang.org

# ==============================================================================
# Advanced runtime overrides
# ==============================================================================

# Optional independent JWT signing key; defaults to SECRET_KEY.
# SIMPLE_JWT_SIGNING_KEY=

# Optional storage credential encryption key; defaults to SECRET_KEY.
# STORAGE_ENCRYPTION_KEY=

# JWT access-token lifetime in hours.
# JWT_ACCESS_TOKEN_HOURS=1

# JWT refresh-token lifetime in hours.
# JWT_REFRESH_TOKEN_HOURS=24

# Number of Gunicorn HTTP workers in the API container.
# API_WORKERS=4

# Gunicorn request timeout in seconds.
# GUNICORN_TIMEOUT=180

# REST API page size.
# API_PAGE_SIZE=10

# Enable organization-scoped API throttling.
# ENABLE_THROTTLING=false

# Organization-scoped API throttle rate.
# THROTTLE_ORG_RATE=600/min

# Force filesystem polling for backend hot reload in development.
# WATCHFILES_FORCE_POLLING=true

# Force filesystem polling for frontend hot reload in development.
# CHOKIDAR_USEPOLLING=true

# Optional frontend API prefix; same-origin deployments leave this empty.
# VITE_API_BASE=

# Agent download URL lifetime in seconds.
# AGENT_RELEASE_URL_TTL_SECONDS=600

# Maximum simultaneous Agent downloads per tenant.
# AGENT_RELEASES_TENANT_MAX_CONCURRENT_DOWNLOADS=20

# Agent download concurrency-slot lifetime in seconds.
# AGENT_RELEASES_SLOT_TTL_SECONDS=3600

# Kopia command timeout in seconds.
# HFL_KOPIA_TIMEOUT_SECONDS=120

# Enable periodic storage maintenance.
# STORAGE_MAINTENANCE_ENABLED=true

# Repository online-status check interval in seconds (minimum 60).
# STORAGE_REPOSITORY_HEALTH_INTERVAL_SECONDS=300

# Time zone used by storage maintenance schedules.
# STORAGE_MAINTENANCE_TIMEZONE=UTC

# Maximum automatic retries for backup execution.
# PROTECTION_BACKUP_AUTO_RETRY_MAX=3

# Cache lifetime for dynamic platform configuration in seconds.
# CONFIG_CACHE_TTL_SECONDS=30

# Require all dynamic configuration keys to exist in the registry.
# CONFIG_STRICT_REGISTRY=false

# Celery hard task limit in seconds.
# CELERY_TASK_TIME_LIMIT=3600

# Celery soft task limit in seconds.
# CELERY_TASK_SOFT_TIME_LIMIT=3000

# Celery result retention in seconds.
# CELERY_RESULT_EXPIRES=604800

# Celery broker visibility timeout in seconds.
# CELERY_VISIBILITY_TIMEOUT=43200

# Acknowledge Celery tasks only after execution.
# CELERY_TASK_ACKS_LATE=true

# ==============================================================================
# Alternative source examples (disabled)
# ==============================================================================

# GitHub download acceleration example.
# GITHUB_DOWNLOAD_MIRROR=https://ghfast.top

# Docker Hub acceleration example.
# DOCKER_DOWNLOAD_MIRROR=docker.m.daocloud.io

# Ubuntu mirror example.
# APT_MIRROR=https://mirrors.tuna.tsinghua.edu.cn

# Python package mirror example.
# PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple

# Trusted host for the Python package mirror example.
# PIP_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn

# npm registry mirror example.
# NPM_REGISTRY=https://registry.npmmirror.com

# Docker CE apt mirror example.
# DOCKER_APT_MIRROR=https://mirrors.aliyun.com/docker-ce/linux/ubuntu
