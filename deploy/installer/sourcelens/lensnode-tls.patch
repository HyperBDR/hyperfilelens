diff --git a/lensnode/lensnode/tls.py b/lensnode/lensnode/tls.py
new file mode 100644
index 0000000000000000000000000000000000000000..00ce7c8ce9c2690ddf8311b12d82067a940ce6d6
--- /dev/null
+++ b/lensnode/lensnode/tls.py
@@ -0,0 +1,47 @@
+"""TLS verification helpers for LensNode outbound HTTPS/WSS connections."""
+
+from __future__ import annotations
+
+import os
+import ssl
+
+_TRUTHY = frozenset({"1", "true", "yes", "on"})
+_FALSY = frozenset({"0", "false", "no", "off"})
+
+
+def _env_truthy(name: str) -> bool:
+    return os.getenv(name, "").strip().lower() in _TRUTHY
+
+
+def tls_insecure_enabled() -> bool:
+    """Return True when TLS certificate verification should be skipped."""
+
+    ssl_verify = os.getenv("LENSNODE_SSL_VERIFY", "").strip().lower()
+    if ssl_verify in _FALSY:
+        return True
+    if ssl_verify in _TRUTHY:
+        return False
+    if _env_truthy("LENSNODE_INSECURE_TLS"):
+        return True
+    if _env_truthy("HFL_INSECURE_TLS"):
+        return True
+    return False
+
+
+def httpx_verify() -> bool:
+    """Return the httpx verify argument for SourceLens requests."""
+
+    return not tls_insecure_enabled()
+
+
+def websocket_ssl_option(url: str) -> bool | ssl.SSLContext | None:
+    """Return the websockets SSL argument for the given URL."""
+
+    if not str(url).lower().startswith("wss://"):
+        return None
+    if tls_insecure_enabled():
+        context = ssl.create_default_context()
+        context.check_hostname = False
+        context.verify_mode = ssl.CERT_NONE
+        return context
+    return True
diff --git a/lensnode/tests/test_tls.py b/lensnode/tests/test_tls.py
new file mode 100644
index 0000000000000000000000000000000000000000..70e5bbdd26d558c243cb18539aa1ef2f278a2ead
--- /dev/null
+++ b/lensnode/tests/test_tls.py
@@ -0,0 +1,42 @@
+from lensnode.tls import (
+    httpx_verify,
+    tls_insecure_enabled,
+    websocket_ssl_option,
+)
+
+
+def test_tls_insecure_from_lensnode_env(monkeypatch):
+    monkeypatch.delenv("LENSNODE_SSL_VERIFY", raising=False)
+    monkeypatch.delenv("HFL_INSECURE_TLS", raising=False)
+    monkeypatch.setenv("LENSNODE_INSECURE_TLS", "1")
+    assert tls_insecure_enabled() is True
+    assert httpx_verify() is False
+
+
+def test_tls_insecure_from_hfl_env(monkeypatch):
+    monkeypatch.delenv("LENSNODE_INSECURE_TLS", raising=False)
+    monkeypatch.delenv("LENSNODE_SSL_VERIFY", raising=False)
+    monkeypatch.setenv("HFL_INSECURE_TLS", "1")
+    assert tls_insecure_enabled() is True
+
+
+def test_tls_verify_explicit_off(monkeypatch):
+    monkeypatch.delenv("LENSNODE_INSECURE_TLS", raising=False)
+    monkeypatch.delenv("HFL_INSECURE_TLS", raising=False)
+    monkeypatch.setenv("LENSNODE_SSL_VERIFY", "0")
+    assert tls_insecure_enabled() is True
+
+
+def test_tls_secure_by_default(monkeypatch):
+    monkeypatch.delenv("LENSNODE_INSECURE_TLS", raising=False)
+    monkeypatch.delenv("HFL_INSECURE_TLS", raising=False)
+    monkeypatch.delenv("LENSNODE_SSL_VERIFY", raising=False)
+    assert tls_insecure_enabled() is False
+    assert httpx_verify() is True
+
+
+def test_websocket_ssl_option_for_wss(monkeypatch):
+    monkeypatch.setenv("LENSNODE_INSECURE_TLS", "1")
+    context = websocket_ssl_option("wss://example.com/ws/")
+    assert context is not None
+    assert context.check_hostname is False
